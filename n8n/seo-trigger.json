    {
      "parameters": {
        "method": "POST",
        "url": "https://api.github.com/repos/raaaf/portfolio-2025/actions/workflows/seo.yml/dispatches",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Accept", "value": "application/vnd.github.v3+json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={ \"ref\": \"main\" }",
        "options": {}
      },
      "id": "dispatch-001",
      "name": "Trigger portfolio-2025",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [480, 200],
