ANTHROPIC_API_KEY=sk-ant-...
SERPAPI_KEY=...
GITHUB_TOKEN=ghp_...

# Pfad zur OAuth2-Credentials-JSON (von Google Cloud Console → Credentials → OAuth 2.0 Client ID → Desktop app)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/oauth-credentials.json

# Beim ersten "seo run" öffnet das CLI einen Browser-Link zur Anmeldung.
# Der Token wird danach unter ~/.seo-cli-token.json gespeichert.
